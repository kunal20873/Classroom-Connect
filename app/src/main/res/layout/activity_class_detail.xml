<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"
    android:fitsSystemWindows="true"
    tools:context=".ClassDetailActivity">

    <!-- क्लास इंफॉर्मेशन कार्ड -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardClassInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/topicname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Topic Name"
                android:textColor="#5A6CFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:background="#5A6CFF" />

            <TextView
                android:id="@+id/teacherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teacher Name"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/classCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="#E8EAF6"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Class ID"
                android:textColor="#3F51B5"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- कॉम्पैक्ट मटेरियल अपलोड कार्ड (अब यह बहुत कम जगह लेगा) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAddMaterial"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:visibility="visible"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardClassInfo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- मटेरियल नाम का इनपुट -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Material Name"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/topicMaterial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:textSize="15sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- नया कॉम्पैक्ट फ़ाइल पिकर लेआउट (Horizontal Row) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="#F8FAFF"
                android:padding="8dp">

                <Button
                    android:id="@+id/btnChoosePdf"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Choose PDF"
                    android:textAllCaps="false"
                    android:textColor="#5A6CFF"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconTint="#5A6CFF" />

                <TextView
                    android:id="@+id/txtSelectedFile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="No file selected"
                    android:textColor="#757575"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- अपलोड बटन (इसकी ऊंचाई थोड़ी कम की ताकि जगह बचे) -->
            <Button
                android:id="@+id/btnAddMaterial"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#5A6CFF"
                android:text="Upload Material"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:id="@+id/MATERIALNAME"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Class Materials"
        android:textColor="#333333"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardAddMaterial" />
    <FrameLayout
        android:id="@+id/materialContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@+id/btnDoubt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/MATERIALNAME">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcViewMaterial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="12dp" />

        <TextView
            android:id="@+id/noMaterial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No material uploaded yet"
            android:textColor="#999999"
            android:visibility="gone" />
    </FrameLayout>

    <Button
        android:id="@+id/btnDoubt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="#5A6CFF"
        android:elevation="8dp"
        android:paddingHorizontal="24dp"
        android:text="Discussion Forum"
        android:textAllCaps="false"
        app:cornerRadius="30dp"
        app:icon="@android:drawable/stat_notify_chat"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>