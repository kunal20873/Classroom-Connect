<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:clickable="true"
    android:focusable="true"
    android:background="#F2F6FF"
    android:layout_gravity="start">
    <!-- Modern Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#5A6CFF"
        android:padding="24dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/profile_icon"
            android:padding="2dp"
            app:strokeWidth="2dp"
            app:strokeColor="#FFFFFF"
            app:shapeAppearanceOverlay="@style/CircleImage"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="User Name"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="user@email.com"
            android:textColor="#E0E7FF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Navigation Items -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnDashboard"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:textColor="#1E293B"
            app:drawableStartCompat="@android:drawable/ic_menu_today"
            app:drawableTint="#5A6CFF"
            android:drawablePadding="16dp"
            android:padding="12dp" />

        <TextView
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:textColor="#1E293B"
            app:drawableStartCompat="@android:drawable/ic_menu_myplaces"
            app:drawableTint="#5A6CFF"
            android:drawablePadding="16dp"
            android:padding="12dp" />

        <TextView
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:textColor="#1E293B"
            app:drawableStartCompat="@android:drawable/ic_menu_preferences"
            app:drawableTint="#5A6CFF"
            android:drawablePadding="16dp"
            android:padding="12dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Polished Logout Section -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurfaceVariant"
        android:alpha="0.1"
        android:layout_marginHorizontal="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Logout"
        android:textColor="#E53935"
        android:textAllCaps="false"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="16dp"
        app:icon="@android:drawable/ic_lock_power_off"
        app:iconTint="#E53935"
        app:iconPadding="16dp" />

</LinearLayout>